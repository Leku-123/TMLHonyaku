					Tooltip: ワールドサイズに応じて、コハク鉱脈の数に適用される倍率。
				}

				PatchScale: {
					DisplayName: "[i:SpiritReforged/AmberFossilSafeItem] （コハク）鉱脈規模"
					Tooltip: コハク鉱脈のサイズを調整する倍率。
				}

				RuinCount: {
					DisplayName: "[i:SpiritReforged/GildedRedSandstoneItem] （遺跡）生成数の範囲"
					Tooltip: オアシスごとに生成される地下砂漠遺跡の数の範囲。
				}

				LightRange: {
					DisplayName: "[i:SpiritReforged/SunDropper] （オアシス）光線の数"
					Tooltip: 地下オアシスに生成される光線数の最小値と、ランダムに加算される範囲。
				}

				ChestItemRange: {
					DisplayName: "[i:1298] （オアシス）宝箱のアイテム数"
					Tooltip: 地下オアシスの宝箱に入るアイテム数の範囲。
				}

				RuinSegments: {
					DisplayName: "[i:SpiritReforged/RedSandstoneSlabItem] （遺跡）区画数の範囲"
					Tooltip: 地下遺跡を構成する区画数の範囲。
				}
			}

			Presets: {
				Overgrown: {
					Name: "[i:2996] 生い茂る"
					Tooltip: 砂漠のオアシスには草木が密生し、すっかり野生化している。なぜこれほど豊かに育つのだろう？
				}

				Petrified: {
					Name: "[i:154] 化石化"
					Tooltip: 砂漠の砂は、永い時を経て化石となった生態系を隠している。すべて発見できるだろうか？
				}

				Ruined: {
					Name: "[i:SpiritReforged/RedSandstoneSlabItem] 廃墟"
					Tooltip: かつて砂漠の地下には、長く忘れ去られた古代文明が栄えていた。その遺跡だけが今も残っている。
				}
			}
		}
	}

	Enums: {
		OceanShape: {
			Default: {
