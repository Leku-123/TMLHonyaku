			Label: 浮上アイテムの上限
			Tooltip: 世界に存在できる浮上アイテムの総数を調整します
		}
	}
}

GenConfigs: {
	UI: {
		Min: すべて最小化
		MinDescription:
			'''
			全設定を、生成量が最も少なくなる値に設定します。
			例えば「木の最大数」のような値は最小に設定されますが、
			「木の生成確率（1/x）」のような値は最大に設定されます。
			'''
		Max: すべて最大化
		MaxDescription:
			'''
			全設定を、生成量が最も多くなる値に設定します。
			例えば「木の最大数」のような値は最大に設定されますが、
			「木の生成確率（1/x）」のような値は最小に設定されます。
			'''
		Preset: プリセット:
		NoPresets: （プリセットなし）
		None: 未選択
		Reset: リセット
		ResetAll: すべてリセット
		Prior: Prior:
		Next: Next:
		True: 有効
		False: 無効
		Total: 合計 {0}
		CustomPresetTooltip: これはカスタムプリセットです！
		Create: カスタムプリセットとして保存
		CantSave: （デフォルトプリセットは保存できない）
		Load: カスタムプリセットを読み込む
		HoverDescription: Spirit Reforgedのワールド生成に関する詳細設定を開く
		FailedToLoad: プリセットのページが一致していません。想定されるページ: {0}
		ConfigNotice:
			'''
			[c/AAAAFF:範囲]は、最小値とランダムな加算値を設定することで機能します。
			表示される値は、ゲーム内でランダム抽選される際に実際に使用される範囲です。
			'''
		LoadError: プリセット（{0}）の読み込み中にエラーが発生しました。Discordに報告し、client.logも確認してください:
		Duplicate: （重複プリセットのため追加されなかった）
	}

	Pages: {
		Savanna: {
			Name: サバンナ
			Description: サバンナ生成に関する細かな要素を調整します。

			Presets: {
				Domesticated: {
					Name: "[i:224] 飼い慣らされたサバンナ"
					Tooltip: 壺が多く、野生生物が少ない、より人の暮らしを感じるサバンナ。
				}

				Infested: {
					Name: "[i:SpiritReforged/TermiteJar] シロアリまみれ"
					Tooltip: しまった！ シロアリだらけだ！ 木を見つけるのは難しいかもしれない。
				}

				Bumpy: {
					Name: "[i:SpiritReforged/Drypowder] でこぼこ"
					Tooltip: 足元注意！ この荒々しいサバンナには、でこぼこや丘が広がっている。
				}
			}

			Members: {
				OverSpawn: {
					DisplayName: "[i:50] 初期スポーン地点に生成"
					Tooltip: 「savanna」シードのように、サバンナを初期スポーン地点の上に生成します。
				}

				Steps: {
					DisplayName: "[i:SpiritReforged/DrywoodPlatformItem] 段差"
					Tooltip: サバンナ生成時に作られる、平坦な段差の数。
				}

				CampsiteChance: {
					DisplayName: "[i:SpiritReforged/SavannaCampfireItem] キャンプ地の生成率"
					Tooltip: キャンプ地が出現する確率を、分母（1/x）で設定します。
				}

				BaseTreeChance: {
					DisplayName: "[i:27] アカシアの木の生成率"
					Tooltip:
						'''
						各タイルに木が生成される確率を、分母（1/x）で設定します。
						木が1本配置されるまでは確率が上がり続け、配置後にリセットされます。
						'''
				}

				PotChance: {
					DisplayName: "[i:SpiritReforged/CommonPotsSavannaItem] 壺の生成率"
					Tooltip:
						'''
						装飾処理で壺が出現する確率を、分母（1/x）で設定します。
						既存タイルは上書きされないため、1に設定しても全タイルに壺が配置されるわけではありません。
						'''
				}

				TermiteChance: {
					DisplayName: "[i:SpiritReforged/TermiteJar] シロアリ塚の生成率"
					Tooltip: 装飾処理でシロアリ塚が出現する確率を、分母（1/x）で設定します。
				}
			}
		}

		SaltFlats: {
			Name: 塩湖
			Description: 塩湖生成に関する細かな要素を調整します。

			Presets: {
				SunkenRuin: {
					Name: "[i:SpiritReforged/CobbledBrickItem] 沈んだ遺跡"
					Tooltip: 古代文明の遺跡が、水に洗われ削り取られている。
				}

				BlankCanvas: {
					Name: "[i:SpiritReforged/GlidingItem] 白紙のキャンバス"
					Tooltip: 何もない、どこまでも続く鏡のような景色が目の前に広がる。
				}

				Dessicated: {
					Name: "[i:1274] 干からびた大地"
