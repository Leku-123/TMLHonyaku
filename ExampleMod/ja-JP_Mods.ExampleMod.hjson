Commands: {
	Common: {
		NoParameters: At least one argument was expected.
		NotInteger: "{0} is not a correct integer value."
	}

	ExampleCoinsCommand: {
		Description: Show the coin rate UI
	}

	ExampleItemCommand: {
		Usage:
			'''
			/item <type|name> [stack]
			type — ItemID of item.
			name — name of Item in current localization.
			Replace spaces in item name with underscores.
			'''
		Description: Spawn an item by name or by typeId
		Error_0: At least one argument was expected.
		Error_1: Unknown item — Must be valid name or 0 < type < {0}
		Error_2: Stack value must be integer, but met: {0}
	}

	ExampleSummonCommand: {
		Usage:
			'''
			/summon type [[~]x] [[~]y] [number]
			type - NPCID of NPC.
			x and y - position of spawn.
			~ - to use position relative to player.
			number - number of NPC's to spawn.
			'''
		Description: Spawn a NPC by NPCID
		Error_0: At least one argument was expected.
		Error_1: "{0} is not a correct integer value."
		Error_2: "{0} is not a correct X position (must be valid integer value)."
		Error_3: "{0} is not a correct Y position (must be valid integer value)."
		Error_4: "{0} is not a correct number (must be valid integer value)."
	}

	ExampleTimeCommand: {
		Usage:
			'''
			/addTime numTicks
			numTicks — positive or negative number in ticks (1 second = 60 ticks).
			'''
		Description: Adds numTicks to fast forward or rewind world time
		Error_0: At least one argument was expected.
		Error_1: "{0} is not a correct integer value."
	}

	ShowFullscreenUICommand: {
		Description: Show the example fullscreen UI
	}

	ModifyServerConfigValueCommand: {
		Usage:
			'''
			/setSomeNumber value
			value — A number to assign to ModConfigShowcaseAcceptClientChanges.SomeNumber
			'''
		Description: Sets ModConfigShowcaseAcceptClientChanges.SomeNumber. Showcases a command setting a ModConfig value and saving that config.
		Error_0: At least one argument was expected.
		Error_1: "{0} is not a correct integer value."
	}
}

