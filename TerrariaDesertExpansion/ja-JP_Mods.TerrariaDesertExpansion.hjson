Items: {
	SerpentFang: {
		DisplayName: 蛇の牙
		Tooltip: 「アッ痛ッ…」
	}

	CactusStaff: {
		DisplayName: サボテンの杖
		Tooltip:
			'''
			辺りを守るサボテンのキャミーを召喚する
			「彼女はトゲトゲしてるってよく言われるけど、キャミーはパーソナルスペースを大事にしてるだけだよ！」
			'''
	}

	SpittingSerpentScepter: {
		DisplayName: 蛇の毒杖
		Tooltip:
			'''
			敵に『毒』を付与する貫通する唾を放つ
			「毒舌な言葉を吐き出すんだ！」
			'''
	}

	CactusLamp: {
		DisplayName: サボテンのランプ
		Tooltip: 「中に電球でも入ってるの？」
	}

	SandShaker: {
		DisplayName: サンドシェイカー
		Tooltip:
			'''
			飛行する敵を地面に叩きつける
			地面にいる敵に追加ダメージの強力な一撃を与える
			'''
	}

	EvilSnakeBannerItem.DisplayName: 邪悪な蛇のバナー
